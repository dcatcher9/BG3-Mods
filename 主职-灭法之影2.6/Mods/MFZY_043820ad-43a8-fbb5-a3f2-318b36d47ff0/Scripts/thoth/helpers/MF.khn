function CHAO_MaxHP60(entity)
    local entity = entity or context.Target
    return ConditionResult(GetStatusDuration('Soul_Gazing_JISHU', entity) > GetStatusDuration('Soul_Gazing_MAXHP', entity))
end

function ClassLevelHigherOrEqualThan(level, class, entity)
    local entity = entity or context.Source
    return ConditionResult(entity.GetClassLevel(class) * 2 + 20 >= level)
end

function ClassLevelEqualThan(level, class, entity)
    local entity = entity or context.Source
    return ConditionResult(entity.GetClassLevel(class) == level)
end

function FelBloodDexInterval(threshold)
    return ConditionResult(GetModifier(context.Source.Dexterity) >= threshold)
end     

function FelBloodStrInterval(threshold)
    return ConditionResult(GetModifier(context.Source.Strength) >= threshold)
end

function FelBloodConInterval(threshold)
    return ConditionResult(GetModifier(context.Source.Constitution) >= threshold)
end

function FelBloodIntInterval(threshold)
    return ConditionResult(GetModifier(context.Source.Intelligence) >= threshold)
end

function FelBloodWisInterval(threshold)
    return ConditionResult(GetModifier(context.Source.Wisdom) >= threshold)
end

function FelBloodChaInterval(threshold)
    return ConditionResult(GetModifier(context.Source.Charisma) >= threshold)
end

