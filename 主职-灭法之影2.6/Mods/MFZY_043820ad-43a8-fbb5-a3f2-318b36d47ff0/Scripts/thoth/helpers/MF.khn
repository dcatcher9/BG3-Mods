function RDDXueQiSpellCheck()
    return (SpellId('Target_Blade_Knife_Blood_Explosion_1') | SpellId('Target_Blade_Knife_Blood_Explosion_2') | SpellId('Target_Blade_Knife_Blood_Explosion_3') | SpellId('Target_Blade_Knife_Blood_Explosion_4') | SpellId('Target_Blade_Knife_Blood_Explosion_5') | SpellId('Target_Blade_Knife_Blood_Explosion_6') | SpellId('Target_Blade_Knife_Blood_Explosion_7') | SpellId('Target_Blade_Knife_Blood_Shadow_1') | SpellId('Target_Blade_Knife_Blood_Shadow_2') | SpellId('Target_Blade_Knife_Blood_Shadow_3') | SpellId('Target_Blade_Knife_Blood_Shadow_4') | SpellId('Target_Blade_Knife_Blood_Shadow_5') | SpellId('Target_Blade_Knife_Blood_Shadow_6') | SpellId('Target_Blade_Knife_Blood_Shadow_7') | SpellId('Zone_Blade_Knife_Killing_1') | SpellId('Zone_Blade_Knife_Killing_2') | SpellId('Zone_Blade_Knife_Killing_3') | SpellId('Zone_Blade_Knife_Killing_4') | SpellId('Zone_Blade_Knife_Killing_5') | SpellId('Zone_Blade_Knife_Killing_6') | SpellId('Zone_Blade_Knife_Killing_7') | SpellId('Zone_Blood_Smoke_Cannon_1') | SpellId('Zone_Blood_Smoke_Cannon_2') | SpellId('Zone_Blood_Smoke_Cannon_3') | SpellId('Rush_Blade_Knife_Blood_Blade') | SpellId('Rush_Blood_Beast'))
