function SoulSpellCheck()
    return (SpellId('Target_Soul_Silk_1') | SpellId('Target_Soul_Silk_2') | SpellId('Target_Soul_Silk_3') | SpellId('Target_Soul_Gazing_T'))
end

function ElementSpellCheck()
    return (SpellId('Target_JIE_LEI'))
end

function MeleeWeaponAttackSpellCheck()
    return not HasStringInSpellRoll('MeleeWeaponAttack')
end

function IsRangedAttack()
    result = context.HitDescription.AttackType == AttackType.RangedWeaponAttack or context.HitDescription.AttackType == AttackType.RangedSpellAttack or context.HitDescription.AttackType == AttackType.RangedUnarmedAttack or context.HitDescription.AttackType == AttackType.RangedOffHandWeaponAttack
	return ConditionResult(result)
end

function LeYuanBi_TargetMaxHpHighThan(value)
    return ConditionResult(context.Target.MaxHP >= value)
end