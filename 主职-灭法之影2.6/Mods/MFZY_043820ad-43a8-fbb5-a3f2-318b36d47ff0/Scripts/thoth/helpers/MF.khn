
function RateOfCustom(threshold)
    local random_num = math.random(1,20)
    return ConditionResult(random_num < threshold)
end

function RateOfCustom30(threshold)
    local random_num = math.random(1,30)
    return ConditionResult(random_num < threshold)
end

function RateOfCustom50(threshold)
    local random_num = math.random(1,50)
    return ConditionResult(random_num < threshold)
end

function RateOfCustom100(threshold)
    local random_num = math.random(1,100)
    return ConditionResult(random_num < threshold)
end

function Has200Pure_Nnergy(entity)
    local entity = entity or context.Target
    return ConditionResult(GetStatusDuration('Pure_Nnergy', entity) >= 200)
end

