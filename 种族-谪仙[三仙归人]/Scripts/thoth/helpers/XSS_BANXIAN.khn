    entity = entity or context.Source

    return HasStatus('BANXIAN_XIULIAN_LINGQI_T',entity) | HasStatus('BANXIAN_XIULIAN_LINGQI_J',entity) | HasStatus('BANXIAN_XIULIAN_LINGQI_S',entity) | HasStatus('BANXIAN_XIULIAN_LINGQI_M',entity)
end

