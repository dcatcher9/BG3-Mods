-- 天光灵根: 火+木+土
function IsTianLingGenGuang(entity)
    local entity = entity or context.Source
    return ConditionResult(GetStatusDuration('BANXIAN_LG_H', entity) >= LG_YI_TIAN_THRESHOLD and GetStatusDuration('BANXIAN_LG_M', entity) >= LG_YI_TIAN_THRESHOLD and GetStatusDuration('BANXIAN_LG_T', entity) >= LG_YI_TIAN_THRESHOLD)
end

-- 天暗灵根: 水+金+木
function IsTianLingGenAn(entity)
    local entity = entity or context.Source
    return ConditionResult(GetStatusDuration('BANXIAN_LG_S', entity) >= LG_YI_TIAN_THRESHOLD and GetStatusDuration('BANXIAN_LG_J', entity) >= LG_YI_TIAN_THRESHOLD and GetStatusDuration('BANXIAN_LG_M', entity) >= LG_YI_TIAN_THRESHOLD)
end

-- 天毒灵根: 木+火+水
function IsTianLingGenDu(entity)
