function IsEquippedMeleeWeapon(entity)
    local entity = entity or context.Source
    local weapon = GetActiveWeapon(entity)
    return IsWeaponOfProficiencyGroup('Daggers', weapon) | IsWeaponOfProficiencyGroup('Shortswords', weapon) | IsWeaponOfProficiencyGroup('Longswords', weapon) | IsWeaponOfProficiencyGroup('Greatswords', weapon) | IsWeaponOfProficiencyGroup('Rapiers', weapon) | IsWeaponOfProficiencyGroup('Scimitars', weapon) | IsWeaponOfProficiencyGroup('Handaxes', weapon) | IsWeaponOfProficiencyGroup('Battleaxes', weapon) | IsWeaponOfProficiencyGroup('Greataxes', weapon) | IsWeaponOfProficiencyGroup('Clubs', weapon) | IsWeaponOfProficiencyGroup('Greatclubs', weapon) | IsWeaponOfProficiencyGroup('Maces', weapon) | IsWeaponOfProficiencyGroup('Warhammers', weapon) | IsWeaponOfProficiencyGroup('Mauls', weapon) | IsWeaponOfProficiencyGroup('Flails', weapon) | IsWeaponOfProficiencyGroup('Quarterstaffs', weapon) | IsWeaponOfProficiencyGroup('Spears', weapon) | IsWeaponOfProficiencyGroup('Glaives', weapon) | IsWeaponOfProficiencyGroup('Halberds', weapon) | IsWeaponOfProficiencyGroup('Pikes', weapon) | IsWeaponOfProficiencyGroup('Tridents', weapon) | IsWeaponOfProficiencyGroup('WarPicks', weapon) | IsWeaponOfProficiencyGroup('Whips', weapon) | IsWeaponOfProficiencyGroup('Lances', weapon) | IsWeaponOfProficiencyGroup('Sickles', weapon) | IsWeaponOfProficiencyGroup('LightHammers', weapon) | IsWeaponOfProficiencyGroup('Javelins', weapon)
end

function IsEquippedBow(entity)
    local entity = entity or context.Source
    local weapon = GetActiveWeapon(entity)
    return IsWeaponOfProficiencyGroup('Longbows', weapon) | IsWeaponOfProficiencyGroup('Shortbows', weapon) | IsWeaponOfProficiencyGroup('LightCrossbows', weapon) | IsWeaponOfProficiencyGroup('HeavyCrossbows', weapon) | IsWeaponOfProficiencyGroup('HandCrossbows', weapon) | IsWeaponOfProficiencyGroup('Darts', weapon) | IsWeaponOfProficiencyGroup('Slings', weapon)
end

function YiDaoRangedSpellCheck()
    return HasStringInSpellRoll('RangedWeaponAttack')
end

function MeleeWeaponAttackCheck()
