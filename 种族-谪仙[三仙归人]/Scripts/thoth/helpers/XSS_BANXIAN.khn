    return ConditionResult(GetStatusDuration('BANXIAN_LG_M', entity) >= LG_YI_TIAN_THRESHOLD and GetStatusDuration('BANXIAN_LG_H', entity) >= LG_YI_TIAN_THRESHOLD and GetStatusDuration('BANXIAN_LG_S', entity) >= LG_YI_TIAN_THRESHOLD)
end

-- 天混沌灵根: 五行皆备达到天异灵根阈值（>=200）
function IsTianLingGenHunDun(entity)
    local entity = entity or context.Source
    return ConditionResult(GetStatusDuration('BANXIAN_LG_H', entity) >= LG_YI_TIAN_THRESHOLD and GetStatusDuration('BANXIAN_LG_T', entity) >= LG_YI_TIAN_THRESHOLD and GetStatusDuration('BANXIAN_LG_J', entity) >= LG_YI_TIAN_THRESHOLD and GetStatusDuration('BANXIAN_LG_S', entity) >= LG_YI_TIAN_THRESHOLD and GetStatusDuration('BANXIAN_LG_M', entity) >= LG_YI_TIAN_THRESHOLD)
end

-- 仙单系灵根：灵根值达到仙灵根阈值（>=300点）即激活仙灵根效果
function IsXianActiveLingGen(Name, entity)
    local entity = entity or context.Source
    return ConditionResult(GetStatusDuration(Name, entity) >= LG_XIAN_THRESHOLD)
end

-- 圣单系灵根：灵根值达到圣灵根阈值（>=1000点）即激活圣灵根效果
function IsShengActiveLingGen(Name, entity)
    local entity = entity or context.Source
    return ConditionResult(GetStatusDuration(Name, entity) >= LG_SHENG_THRESHOLD)
end

