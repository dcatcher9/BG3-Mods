local __util = require 'larian.util'

function Shenshi_SourceSpellDC(fallbackDC, entity, ability)
    entity = entity or context.Source
	local spellDC = fallbackDC or 10 -- Global default so that we don't return 0
    ability = ability or context.PreferredCastingAbility
	if entity.IsValid then
		spellDC = CalculateSpellDC(ability, entity)
	end
	return spellDC
end


function SpellDC_HEHUAN()
    if not context.Source or not context.Source.IsValid then return 8 end
    return 8 + context.Source.ProficiencyBonus + GetModifier(context.Source.Constitution)
end

function DuLGSaveDC()
    if not context.Source or not context.Source.IsValid then return 8 end
    return 8 + context.Source.Level
end

function SpellDC_ShenshiControl()
    if not context.Source or not context.Source.IsValid then return 8 end
    if not context.Target or not context.Target.IsValid then
        return 99
    end
    -- 标准神识法术DC：8 + 熟练加值 + 感知修正 + 当前神识点
    local spellDC = 8 + context.Source.ProficiencyBonus + GetModifier(context.Source.Wisdom)
    local ssRes = context.Source.ActionResources and context.Source.ActionResources.Resources and context.Source.ActionResources.Resources['0032115b-77c3-43c8-9385-630e657b2fcc']
    if ssRes and ssRes[1] then
        spellDC = spellDC + math.floor(ssRes[1].Amount)
    end

    -- 无魂/构造体/不死生物无法抵抗神识，自动失败
    if Tagged('NOSOUL', context.Target) == 1 or Tagged('CONSTRUCT', context.Target) == 1 or Tagged('UNDEAD', context.Target) == 1 then
        spellDC = 99
    end

    return spellDC
end

function IsTargetHPLess()
    if not context.Target or not context.Target.IsValid then
        return ConditionResult(false)
    end
    local result = context.Source.HP > context.Target.HP
    return ConditionResult(result)
end

function TargetHPLessThanYourStrength()
    if not context.Target or not context.Target.IsValid then
        return ConditionResult(false)
    end
    local result = context.Source.Strength >= context.Target.HP
    return ConditionResult(result)
end

function BLEEDINGPercentageMoreThan(value,entity)
    local entity = entity or context.Source
    local result = GetStatusDuration('BLEEDING', entity) > value
    return ConditionResult(result)
end

function IsTargetWeaker()
    if not context.Target or not context.Target.IsValid then
        return ConditionResult(false)
    end
    local cond = GetStatusDuration('BANXIAN_DH_YEAR', context.Source) >= GetStatusDuration('BANXIAN_DH_YEAR', context.Target) and GetStatusDuration('BANXIAN_DH_YEAR', context.Source) >= context.Target.Level
    return ConditionResult(cond) | CantResist()
end

function CharacterLevelGreaterThanTarget()
    if not context.Target or not context.Target.IsValid then
        return ConditionResult(false, {ConditionError("IsNotCharacterLevelGreaterThan")})
    end
    return ConditionResult(context.Source.Level >= context.Target.Level, {ConditionError("IsNotCharacterLevelGreaterThan")})
end

function HeHuanTarget(entity)
    local entity = entity or context.Target
    local result = Tagged('HUMANOID',entity) | Tagged('FIEND',entity) | Tagged('CELESTIAL',entity) | Tagged('UNDEAD',entity) | Tagged('BEAST',entity)
    return ConditionResult(result.Result, {ConditionError("HeHuanTarget")})
end

function CantResist(entity)
    local entity = entity or context.Target
    local result =  HasStatus('SG_Fleeing',entity) | HasStatus('SG_Incapacitated',entity) | HasStatus('SG_Unconscious',entity) | HasStatus('SG_Restrained',entity) | HasStatus('KNOCKED_OUT',entity) | HasStatus('SG_Dominated',entity) | HasStatus('SG_Sleeping',entity) | HasStatus('SG_Sleeping_Magical',entity) | HasStatus('SG_Charmed',entity) | HasStatus('SG_Charmed_Subtle',entity) | HasStatus('SG_Drunk',entity) | HasStatus('DOMINATE_HEHUAN',entity) | HasStatus('SG_Paralyzed',entity) | HasStatus('SG_Stunned',entity) | HasStatus('SG_Petrified',entity) | HasStatus('SG_Frightened',entity) | HasStatus('SG_Prone',entity) | HasStatus('SG_Taunted',entity)
    return ConditionResult(result.Result, {ConditionError("CanResist")})
end

function ZhouTianNiXingCheck()
    return HasStatus('SG_Rage') | HasStatus('MENTAL_ARROW') | HasStatus('MENTALSLAM')
end

function IgnoreNiXingCheck()
