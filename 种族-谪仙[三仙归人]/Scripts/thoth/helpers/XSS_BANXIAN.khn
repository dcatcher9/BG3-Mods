-- 灵根阈值常量
local LG_THRESHOLD          = 25    -- 普通灵根
local LG_YI_THRESHOLD       = 50    -- 普通异灵根 (× 2)
local LG_TIAN_THRESHOLD     = 100   -- 天灵根
local LG_YI_TIAN_THRESHOLD  = 200   -- 天异灵根 (× 2)
local LG_XIAN_THRESHOLD     = 300   -- 仙灵根
local LG_YI_XIAN_THRESHOLD  = 600   -- 仙异灵根 (× 2)
local LG_SHENG_THRESHOLD    = 1000  -- 圣灵根
local LG_YI_SHENG_THRESHOLD = 2000  -- 圣异灵根 (× 2)

-- 冰灵根: 水+土 均达到阈值(>=LG_YI_THRESHOLD)
function YiLingGen_Bing(entity)
    local entity = entity or context.Source
    return ConditionResult(GetStatusDuration('BANXIAN_LG_S', entity) >= LG_YI_THRESHOLD and GetStatusDuration('BANXIAN_LG_T', entity) >= LG_YI_THRESHOLD)
end

-- 雷灵根: 金+水 均达到阈值
function YiLingGen_Lei(entity)
    local entity = entity or context.Source
    return ConditionResult(GetStatusDuration('BANXIAN_LG_J', entity) >= LG_YI_THRESHOLD and GetStatusDuration('BANXIAN_LG_S', entity) >= LG_YI_THRESHOLD)
end

