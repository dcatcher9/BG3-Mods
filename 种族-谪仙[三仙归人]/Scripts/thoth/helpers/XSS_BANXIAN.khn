    return HasStatus('BANXIAN_XIULIAN_LINGQI_T',entity) | HasStatus('BANXIAN_XIULIAN_LINGQI_J',entity) | HasStatus('BANXIAN_XIULIAN_LINGQI_H',entity) | HasStatus('BANXIAN_XIULIAN_LINGQI_M',entity)
end

function BanxianXiulianKiFlashCheck_M(entity)
    entity = entity or context.Source

    return ConditionResult(GetStatusDuration('BANXIAN_XIULIAN_LINGQI_M', entity) >= LG_THRESHOLD)
end

function BanxianXiulianKiFlashCheck_MN(entity)
    entity = entity or context.Source

    return HasStatus('BANXIAN_XIULIAN_LINGQI_T',entity) | HasStatus('BANXIAN_XIULIAN_LINGQI_J',entity) | HasStatus('BANXIAN_XIULIAN_LINGQI_S',entity) | HasStatus('BANXIAN_XIULIAN_LINGQI_H',entity)
end

function BanxianXiulianKiFlashCheck_ALL(entity)
    entity = entity or context.Source

    return ConditionResult(GetStatusDuration('BANXIAN_XIULIAN_LINGQI_H', entity) >= 2 and GetStatusDuration('BANXIAN_XIULIAN_LINGQI_T', entity) >= 2 and GetStatusDuration('BANXIAN_XIULIAN_LINGQI_J', entity) >= 2 and GetStatusDuration('BANXIAN_XIULIAN_LINGQI_S', entity) >= 2 and GetStatusDuration('BANXIAN_XIULIAN_LINGQI_M', entity) >= 2)
end

function BanxianXiulianKiFlashCheck_ALLN(entity)
    entity = entity or context.Source

    return ConditionResult(GetStatusDuration('BANXIAN_XIULIAN_LINGQI_H', entity) == GetStatusDuration('BANXIAN_XIULIAN_LINGQI_T', entity) and GetStatusDuration('BANXIAN_XIULIAN_LINGQI_J', entity) == GetStatusDuration('BANXIAN_XIULIAN_LINGQI_S', entity) and GetStatusDuration('BANXIAN_XIULIAN_LINGQI_H', entity) == GetStatusDuration('BANXIAN_XIULIAN_LINGQI_M', entity) and GetStatusDuration('BANXIAN_XIULIAN_LINGQI_H', entity) == GetStatusDuration('BANXIAN_XIULIAN_LINGQI_J', entity))
end




function BanxianXiulianKiFlashCheck(entity)
    entity = entity or context.Source

    return (BanxianXiulianKiFlashCheck_H(entity) & ~BanxianXiulianKiFlashCheck_HN(entity)) | (BanxianXiulianKiFlashCheck_T(entity) & ~BanxianXiulianKiFlashCheck_TN(entity)) | (BanxianXiulianKiFlashCheck_J(entity) & ~BanxianXiulianKiFlashCheck_JN(entity))  | (BanxianXiulianKiFlashCheck_S(entity) & ~BanxianXiulianKiFlashCheck_SN(entity))  | (BanxianXiulianKiFlashCheck_M(entity) & ~BanxianXiulianKiFlashCheck_MN(entity))  | (BanxianXiulianKiFlashCheck_ALL(entity) & BanxianXiulianKiFlashCheck_ALLN(entity))
end

function Ki_FlashCheck(entity)
    entity = entity or context.Source

    return ConditionResult(GetStatusDuration('BANXIAN_XIULIAN_LINGQI_JINGLIAN', entity) >= (GetStatusDuration('BANXIAN_LG_H', entity) + GetStatusDuration('BANXIAN_LG_T', entity) + GetStatusDuration('BANXIAN_LG_J', entity) + GetStatusDuration('BANXIAN_LG_S', entity) + GetStatusDuration('BANXIAN_LG_M', entity))/5)
end



function HasYiHuo(entity)
    entity = entity or context.Source

    return HasPassive('BANXIAN_Fire_of_Gold',entity) | HasPassive('BANXIAN_Fire_of_Ghost',entity) | HasPassive('BANXIAN_Fire_of_ThreeMei',entity) | HasPassive('BANXIAN_Fire_of_Purple',entity) | HasPassive('BANXIAN_Fire_of_SixDing',entity)
end


function Shenshi_TelekinesisCheck()
    local result = Dead() | Item() | Ally()
    if not result.Result then
        local st = ~SavingThrow(Ability.Strength, Shenshi_SourceSpellDC())
        return ConditionResult(st.Result, {}, {}, st.Chance)
    end

    return result
end


function IsPerfectParry()
    return ConditionResult(context.HitDescription.TotalDamageDone <= 0)
end

function IsFlatValueInterruptInteresting_Enemy(max, entity)
    local entity = entity or context.Target
    local max = max or 0
    if context.InterruptedRoll.RollCritical ~= RollCritical.None then
        return ConditionResult(false, {ConditionError("IsCriticalFailSuccess")})
    end

    local rollSuccess = context.InterruptedRoll.Total >= context.InterruptedRoll.Difficulty
    local result = rollSuccess and ((context.InterruptedRoll.Total - context.InterruptedRoll.Difficulty) < max)

    return ConditionResult(result)
end





function ZhengLeiGu_TwinnedProjectileSpellCheck()
    return ~AreaRadiusGreaterThan(0) & (HasSpellFlag(SpellFlags.Spell) | NonSpellMetamagicAbilities()) & SpellTypeIs(SpellType.Projectile) & ~MetamagicExclusionSpells() & ~SpellId('Projectile_WitchBolt')
end

function ZhengLeiGu_TwinnedTargetSpellCheck()
    return TargetRadiusGreaterThan(1.5) & ~AreaRadiusGreaterThan(0) & (HasSpellFlag(SpellFlags.Spell) | NonSpellMetamagicAbilities()) & SpellTypeIs(SpellType.Target) & ~HasFunctor(StatsFunctorType.Summon) & ~MetamagicExclusionSpells()
end

function ZhengLeiGu_TwinnedTargetTouchSpellCheck()
    return TargetRadiusGreaterThan(0) & ~TargetRadiusGreaterThan(1.5) & ~AreaRadiusGreaterThan(0) & (HasSpellFlag(SpellFlags.Spell) | NonSpellMetamagicAbilities()) & SpellTypeIs(SpellType.Target) & ~HasFunctor(StatsFunctorType.Summon) & ~MetamagicExclusionSpells()
end





function BanXian_LingQiBianYi_Lei(entity)
    local entity = entity or context.Source

    return HasStatus('BANXIAN_LG_LEI',entity) | HasStatus('BANXIAN_LG_LEI_TIAN',entity)
end

function BanXian_LingQiBianYi_Bing(entity)
    local entity = entity or context.Source

    return (HasStatus('BANXIAN_LG_BING',entity) | HasStatus('BANXIAN_LG_BING_TIAN',entity)) & ~(HasStatus('BANXIAN_LG_LEI',entity) | HasStatus('BANXIAN_LG_LEI_TIAN',entity))
end

function BanXian_LingQiBianYi_Du(entity)
    local entity = entity or context.Source

    return (HasStatus('BANXIAN_LG_DU',entity) | HasStatus('BANXIAN_LG_DU_TIAN',entity)) & ~(HasStatus('BANXIAN_LG_BING',entity) | HasStatus('BANXIAN_LG_BING_TIAN',entity)) & ~(HasStatus('BANXIAN_LG_LEI',entity) | HasStatus('BANXIAN_LG_LEI_TIAN',entity))
end

function BanXian_LingQiBianYi_None(entity)
    local entity = entity or context.Source

    return ~(HasStatus('BANXIAN_LG_BING',entity) | HasStatus('BANXIAN_LG_BING_TIAN',entity) | HasStatus('BANXIAN_LG_LEI',entity) | HasStatus('BANXIAN_LG_LEI_TIAN',entity) | HasStatus('BANXIAN_LG_DU',entity) | HasStatus('BANXIAN_LG_DU_TIAN',entity))
end



function OffHandAttackSpell()
    return HasStringInSpellRoll('WeaponAttack') & HasUseCosts('BonusActionPoint',false)
end


