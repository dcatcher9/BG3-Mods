end

function ZhouTianWorkCheck()
    local result = (HasStatus('CUITI_ZHOUTIAN_1') & HasPassive('CuiTi_ZhouTian_1')) | (HasStatus('CUITI_ZHOUTIAN_2') & HasPassive('CuiTi_ZhouTian_2')) | (HasStatus('CUITI_ZHOUTIAN_3') & HasPassive('CuiTi_ZhouTian_3')) | (HasStatus('CUITI_ZHOUTIAN_4') & HasPassive('CuiTi_ZhouTian_4')) | (HasStatus('CUITI_ZHOUTIAN_5') & HasPassive('CuiTi_ZhouTian_5')) | (HasStatus('CUITI_ZHOUTIAN_6') & HasPassive('CuiTi_ZhouTian_6')) | (HasStatus('CUITI_ZHOUTIAN_7') & HasPassive('CuiTi_ZhouTian_7')) | (HasStatus('CUITI_ZHOUTIAN_8') & HasPassive('CuiTi_ZhouTian_8')) | (HasStatus('CUITI_ZHOUTIAN_9') & HasPassive('CuiTi_ZhouTian_9')) | (HasStatus('CUITI_ZHOUTIAN_10') & HasPassive('CuiTi_ZhouTian_10')) | (HasStatus('CUITI_ZHOUTIAN_11') & HasPassive('CuiTi_ZhouTian_11')) | (HasStatus('CUITI_ZHOUTIAN_12') & HasPassive('CuiTi_ZhouTian_12'))
    return ConditionResult(result.Result, {ConditionError("NotBreakXueQiao")})
end

