function ColdDamageTypeSpellCheck()
    return IsSpell() & (HasUseCosts('SpellSlot') | HasUseCosts('WarlockSpellSlot')) & SpellDamageTypeIs(DamageType.Cold)
end

function LightningDamageTypeSpellCheck()
    return IsSpell() & (HasUseCosts('SpellSlot') | HasUseCosts('WarlockSpellSlot')) & SpellDamageTypeIs(DamageType.Lightning)
end



function LightningChargeACCheck(entity)
    entity = entity or context.Source

    local result = GetStatusDuration('MAG_CHARGED_LIGHTNING', entity) ~= GetStatusDuration('MAG_CHARGED_LIGHTNING_LGLEI_AC', entity)
    return ConditionResult(result)
end



function WZPLGLZDuration(value,entity)
    value = value or 0
    entity = entity or context.Source

    local result = GetStatusDuration('BANXIAN_WZPLG_LZ', entity) == value
    return ConditionResult(result)
end







function BanXianShenshiControlCheck(entity)
    entity = entity or context.Target
    local level = entity.Level*2
    local result = HasActionResource('ShenshiPoint', level, 0, false, false, context.Source)

    return ConditionResult(result.Result, {ConditionError("TargetLevelHigherThanShenshi")})
end

function ConcentrationSpellCheck()
    return HasSpellFlag(SpellFlags.Concentration) & ~(SpellId('BANXIAN_YYNoMoreConcentration') | SpellId('Shout_WildShape_Bear_YaoXian') | SpellId('Shout_WildShape_Raven_YaoXian') | SpellId('Shout_WildShape_Crab_YaoXian') | SpellId('Shout_WildShape_Frog_YaoXian') | SpellId('Shout_WildShape_Panther_YaoXian') | SpellId('Shout_WildShape_Rat_YaoXian') | SpellId('Shout_WildShape_SaberTooth_YaoXian') | SpellId('Shout_WildShape_Spider_YaoXian') | SpellId('Shout_WildShape_Wolf_YaoXian'))
end

function CanShenshiCheck()
    if not context.Target or not context.Target.IsValid then
        return ConditionResult(false, {ConditionError("CannotCheckTarget")})
    end
    return ConditionResult(GetModifier(context.Source.Wisdom) >= GetModifier(context.Target.Wisdom), {ConditionError("CannotCheckTarget")})
end


function IsZhenfaFlags(entity)
    entity = entity or context.Target
    return HasStatus('BANXIAN_ZHENFA_FLAGS_JULING_AURA_QIAN',entity) | HasStatus('BANXIAN_ZHENFA_FLAGS_JULING_AURA_KUN',entity) | HasStatus('BANXIAN_ZHENFA_FLAGS_JULING_AURA_XUN',entity) | HasStatus('BANXIAN_ZHENFA_FLAGS_JULING_AURA_ZHEN',entity) | HasStatus('BANXIAN_ZHENFA_FLAGS_JULING_AURA_KAN',entity) | HasStatus('BANXIAN_ZHENFA_FLAGS_JULING_AURA_LI',entity) | HasStatus('BANXIAN_ZHENFA_FLAGS_JULING_AURA_GEN',entity) | HasStatus('BANXIAN_ZHENFA_FLAGS_JULING_AURA_DUI',entity)
end


function CuiHuoSpellCheck()
    return SpellId('BANXIAN_FaBao_FireBreath') | SpellId('BANXIAN_FaBao_FireBreath_Cone') | SpellId('BANXIAN_FaBao_FireBreath_Line') | SpellId('BANXIAN_FaBao_FireBreath_YAO') | SpellId('BANXIAN_FaBao_FireBreath_YAO_Cone') | SpellId('BANXIAN_FaBao_FireBreath_YAO_Line')
end










function BanxianXiulianKiFlashCheck_H(entity)
    entity = entity or context.Source

    return ConditionResult(GetStatusDuration('BANXIAN_XIULIAN_LINGQI_H', entity) >= LG_THRESHOLD)
end

