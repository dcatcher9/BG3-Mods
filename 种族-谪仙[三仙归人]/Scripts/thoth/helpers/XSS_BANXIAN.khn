    entity = entity or context.Source

    return HasStatus('BANXIAN_XIULIAN_LINGQI_T',entity) | HasStatus('BANXIAN_XIULIAN_LINGQI_H',entity) | HasStatus('BANXIAN_XIULIAN_LINGQI_S',entity) | HasStatus('BANXIAN_XIULIAN_LINGQI_M',entity)
end

function BanxianXiulianKiFlashCheck_S(entity)
    entity = entity or context.Source

    return ConditionResult(GetStatusDuration('BANXIAN_XIULIAN_LINGQI_S', entity) >= LG_THRESHOLD)
end

function BanxianXiulianKiFlashCheck_SN(entity)
