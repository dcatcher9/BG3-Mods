function HasLingGen(entity)
    local entity = entity or context.Target
    local result = HasStatus('BANXIAN_LG_H',entity) | HasStatus('BANXIAN_LG_T',entity) | HasStatus('BANXIAN_LG_J',entity) | HasStatus('BANXIAN_LG_S',entity) | HasStatus('BANXIAN_LG_M',entity)

    return ConditionResult(result.Result, {ConditionError("notHasLingGen")})
end


-- 阈值灵根检测：灵根值达到阈值（>=10点）即激活效果
function IsActiveLingGen(Name,entity)
    local entity = entity or context.Source
    return ConditionResult(GetStatusDuration(Name, entity) >= LG_THRESHOLD)
end

-- 天单系灵根：灵根值达到天灵根阈值（>=100点）即激活天灵根效果
function IsTianActiveLingGen(Name,entity)
    local entity = entity or context.Source
    return ConditionResult(GetStatusDuration(Name, entity) >= LG_TIAN_THRESHOLD)
end

-- 天异灵根：所有组合元素均达到天异灵根阈值（>=200）
